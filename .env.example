# EmailJS credentials — get these from https://dashboard.emailjs.com
# 1. Create a service (e.g. Gmail) -> copy its Service ID
# 2. Create an email template with variables: customer_name, customer_email,
#    customer_phone, customer_age, interested_product, budget, message, submitted_at
# 3. Copy the Template ID and your account's Public Key (Account > General)

VITE_API_URL=http://localhost:5000
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
